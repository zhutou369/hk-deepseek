<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - FinalShell下载</title>
    <meta name="keywords" content="SSH工具, FinalShell下载, Linux服务器管理, 远程桌面, 终端模拟器">
    <style>
/* 🌟 核心修复 1：防止文字、长链接、长英文单词撑破白底容器 */
.article-body {
    font-size: 1.1rem;
    color: #444;
    text-align: justify;
    word-break: break-word;     /* 允许在长单词或 URL 内部换行 */
    overflow-wrap: break-word;  /* 响应式溢出包裹 */
    word-wrap: break-word;
}

/* 🌟 核心修复 2：强制固定图片大小，100% 严丝合缝卡在白底容器内，绝不越界 */
.article-body img {
    max-width: 100% !important; /* 图片最大宽度不能超过它的父级容器 */
    height: auto !important;    /* 高度自动等比例缩放，防止图片变形 */
    display: block;             /* 独占一行排版 */
    margin: 20px auto;          /* 上下留出间距，且居中对齐 */
    border-radius: 6px;         /* 顺便加个圆角让它更美观 */
    box-shadow: 0 2px 8px rgba(0,0,0,0.05); /* 轻微阴影提升质感 */
}

/* 🌟 核心修复 3：防止 Gemini 生成的 markdown 代码块（pre/code）横向溢出 */
.article-body pre, .article-body code {
    max-width: 100% !important;
    white-space: pre-wrap !important; /* 代码太长时自动折行，而不是产生横向滚动条 */
    word-break: break-all !important;
}
        /* 页面基础样式 */
        :root { --main-green: #075E54; --accent-green: #128C7E; --light-green: #25D366; --bg-gray: #f0f2f5; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.8; color: #333; margin: 0; background: var(--bg-gray); }
        
        .post-container { max-width: 900px; margin: 40px auto; background: #fff; padding: 45px; border-radius: 12px; box-shadow: 0 5px 25px rgba(0,0,0,0.05); }
        
        header { text-align: center; margin-bottom: 30px; }
        header a { color: var(--main-green); text-decoration: none; font-weight: bold; font-size: 1.2rem; }

        h1 { color: var(--main-green); border-bottom: 2px solid #eee; padding-bottom: 20px; font-size: 2rem; margin-top: 0; }
        .article-meta { color: #999; font-size: 0.9rem; margin-bottom: 30px; }
        
        .article-body { font-size: 1.1rem; color: #444; text-align: justify; }
        .article-body h2 { color: var(--accent-green); border-left: 5px solid var(--light-green); padding-left: 15px; margin-top: 40px; }
        .article-body p { margin-bottom: 20px; }

        /* 面包屑导航样式微调 */
        .breadcrumb-nav a { transition: color 0.2s; }
        .breadcrumb-nav a:hover { color: var(--accent-green) !important; }

        /* 互链导航组件 */
        .nav-links {
            display: flex;
            justify-content: space-between;
            align-items: stretch;
            gap: 20px;
            padding-top: 30px;
            border-top: 2px solid #f4f4f4;
            margin-top: 50px;
        }
        .nav-box { flex: 1; display: flex; flex-direction: column; }
        .nav-item {
            flex: 1;
            padding: 15px;
            border-radius: 8px;
            background: #f8f9fa;
            text-decoration: none;
            color: var(--accent-green);
            transition: all 0.3s;
            border: 1px solid transparent;
            display: flex;
            flex-direction: column;
        }
        .nav-item:hover {
            background: #fff;
            border-color: var(--accent-green);
            box-shadow: 0 4px 12px rgba(18,140,126,0.1);
        }
        .nav-label { font-size: 0.8rem; color: #999; margin-bottom: 5px; }
        .nav-title { font-weight: bold; font-size: 1rem; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
        .next { text-align: right; align-items: flex-end; }

        /* 🌟 新增：底部内页专属最新文章列表组件样式 */
        .post-list-section { margin-top: 45px; padding-top: 30px; border-top: 2px solid #f4f4f4; }
        .post-list-section h3 { color: #334155; font-size: 1.3rem; margin-bottom: 18px; font-weight: 700; }
        .embedded-post-list { list-style: none; padding: 0; margin: 0; }
        .embedded-post-item { padding: 12px 0; border-bottom: 1px dashed #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
        .embedded-post-item:last-child { border-bottom: none; }
        .embedded-post-item a { color: #475569; text-decoration: none; font-size: 1.05rem; font-weight: 500; transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 75%; }
        .embedded-post-item a:hover { color: var(--accent-green); }
        .embedded-post-date { color: #94a3b8; font-size: 0.9rem; }

        /* 站群随机互链 */
        .footer-links { margin-top: 40px; padding: 20px; background: #fdfdfd; border-radius: 8px; text-align: center; border: 1px solid #eee; }
        .footer-links strong { display: block; margin-bottom: 10px; color: #666; font-size: 0.9rem; }
        .link-item { display: inline-block; margin: 5px 10px; color: #888; text-decoration: none; font-size: 14px; }
        .link-item:hover { color: var(--light-green); }

        @media (max-width: 600px) {
            .nav-links { flex-direction: column; }
            .embedded-post-item { flex-direction: column; align-items: flex-start; gap: 4px; }
            .embedded-post-item a { max-width: 100%; }
        }
    </style>
    
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script>
    <script>LA.init({id:"3K7l95Zodr0uFrIN",ck:"3K7l95Zodr0uFrIN"})</script>
</head>
<body>

    <header>
        <div style="padding: 20px;"><a href="/">FinalShell技术支持</a></div>
    </header>

    <article class="post-container">
        <!-- 面包屑导航组件 -->
        <nav aria-label="breadcrumb" class="breadcrumb-nav" style="font-size: 0.9rem; margin-bottom: 20px; color: #666;">
            <a href="/" style="color: #666; text-decoration: none;">首页</a>
            <span style="margin: 0 8px; color: #ccc;">&gt;</span>
            <a href="/blog/" style="color: #666; text-decoration: none;">文章列表</a>
            <span style="margin: 0 8px; color: #ccc;">&gt;</span>
            <span style="color: #999;">正文</span>
        </nav>

        <h1>{{ title }}</h1>
        <div class="article-meta">
            {% if date %}
                发布日期：{{ date | dateFilter }}
            {% endif %}
        </div>
        
        <div class="article-body">
            {{ content | safe }}
        </div>

        <!-- 🌟 核心修改点 1：使用 Eleventy 内置全局集合函数精准定位“上一篇”与“下一篇” -->
        {% set previousPost = collections.blog | getPreviousCollectionItem(page) %}
        {% set nextPost = collections.blog | getNextCollectionItem(page) %}

        <nav class="nav-links">
            <div class="nav-box">
            {% if previousPost %}
                <a href="{{ previousPost.url }}" class="nav-item prev">
                    <span class="nav-label">← 上一篇文章</span>
                    <span class="nav-title">{{ previousPost.data.title }}</span>
                </a>
            {% endif %}
            </div>
            
            <div class="nav-box">
            {% if nextPost %}
                <a href="{{ nextPost.url }}" class="nav-item next">
                    <span class="nav-label">下一篇文章 →</span>
                    <span class="nav-title">{{ nextPost.data.title }}</span>
                </a>
            {% endif %}
            </div>
        </nav>

        <!-- 🌟 核心修改点 2：在文章正文底部分流，无缝嵌入最新文章列表组件（安全计数锁防止越界报错） -->
        <section class="post-list-section">
            <h3>📂 相关技术指南推荐</h3>
            <ul class="embedded-post-list">
                {% set loopCount = 0 %}
                {% for item in collections.blog | reverse %}
                    {% if loopCount < 5 %}
                        <li class="embedded-post-item">
                            <a href="{{ item.url }}">{{ item.data.title }}</a>
                            <span class="embedded-post-date">{{ item.date | dateFilter }}</span>
                        </li>
                        {% set loopCount = loopCount + 1 %}
                    {% endif %}
                {% else %}
                    <li style="color: #94a3b8; font-size: 0.95rem;">暂无相关推荐内容</li>
                {% endfor %}
            </ul>
        </section>

        <div class="footer-links">
            <strong>推荐阅读</strong>
            <div id="random-links-wrap">
                <!-- 注入的站群/同站随机链 -->
            </div>
        </div>
        
        <div style="text-align: center; margin-top: 40px; padding-bottom: 20px;">
            <a href="/" style="color: #999; text-decoration: none; font-size: 0.9rem;">返回首页入口</a>
        </div>
    </article>
<script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script>
<script>LA.init({id:"3K7l95Zodr0uFrIN",ck:"3K7l95Zodr0uFrIN"})</script>
</body>
</html>