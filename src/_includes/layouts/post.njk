---
layout: layouts/base.njk
---

<div class="container" style="padding: 60px 0;">
  <article>
    <header style="margin-bottom: 50px; text-align: center;">
      <h1 style="font-size: 42px; line-height: 1.2; color: var(--bg-dark); margin: 0 0 20px;">{{ title }}</h1>
      <div style="color:#94a3b8; font-size:14px;">
        發布時間：{{ date | dateFilter }}{% if updated %} · 更新於 {{ updated | dateFilter }}{% endif %}
        · {{ site.brand }}
      </div>
      {% if tags and tags.length > 1 %}
        <div class="post-tag-list" style="justify-content:center; margin-top:12px;">
          {% for tag in tags %}
            {% if tag != "posts" %}
              <a href="/tags/{{ tag | tagSlug }}/" style="margin:0 6px; color:var(--primary); text-decoration:none; font-size:13px;">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </header>

    {% if coverImage %}
    <figure class="post-cover">
      <img src="{{ coverImage }}" alt="{{ title }}" width="800" height="450" loading="eager" decoding="async">
    </figure>
    {% endif %}

    <section class="post-body" style="font-size: 17px; color: #334155; line-height: 1.8; max-width: 800px; margin: 0 auto;">
      {{ content | safe }}
    </section>

    <div style="max-width: 800px; margin: 80px auto 40px; display: flex; justify-content: space-between; border-top: 1px solid var(--border); padding-top: 30px;">
      {% set prevPost = collections.indexablePosts | getPreviousCollectionItem(page) %}
      {% set nextPost = collections.indexablePosts | getNextCollectionItem(page) %}
      <div style="width:45%;">
        {% if prevPost %}
          <div style="font-size:12px; color:#94a3b8; margin-bottom:5px;">上一篇</div>
          <a href="{{ prevPost.url }}" style="text-decoration:none; color:var(--bg-dark); font-weight:600;">{{ prevPost.data.title }}</a>
        {% endif %}
      </div>
      <div style="width:45%; text-align:right;">
        {% if nextPost %}
          <div style="font-size:12px; color:#94a3b8; margin-bottom:5px;">下一篇</div>
          <a href="{{ nextPost.url }}" style="text-decoration:none; color:var(--bg-dark); font-weight:600;">{{ nextPost.data.title }}</a>
        {% endif %}
      </div>
    </div>

    <div style="max-width: 800px; margin: 40px auto; background: #f8fafc; padding: 40px; border-radius: 16px;">
      <h3 style="margin-top:0; font-size:18px;">最新教程</h3>
      <ul style="list-style:none; padding:0; margin:20px 0 0; display: grid; gap: 15px;">
        {% for item in collections.indexablePosts | limit(5) %}
          <li><a href="{{ item.url }}" style="text-decoration:none; color:var(--text-main); font-size:15px; border-bottom:1px solid #e2e8f0; display:block; padding-bottom:10px;">{{ item.data.title }}</a></li>
        {% endfor %}
      </ul>
      <div style="margin-top:20px; text-align:right;">
        <a href="/posts/" style="color:var(--primary); text-decoration:none; font-size:14px; font-weight:700;">查看全部文章 &raquo;</a>
      </div>
    </div>
  </article>
</div>

<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date | htmlDate,
  "dateModified": (updated | htmlDate) if updated else (date | htmlDate),
  "author": { "@type": "Organization", "name": site.brand },
  "publisher": { "@type": "Organization", "name": site.brand, "url": site.url },
  "image": site.url + (coverImage or ogImage or site.ogImage or "/static/og-default.png"),
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
</script>
<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首頁", "item": site.url + "/" },
    { "@type": "ListItem", "position": 2, "name": "技術文章", "item": site.url + "/posts/" },
    { "@type": "ListItem", "position": 3, "name": title, "item": site.url + page.url }
  ]
} | dump | safe }}
</script>
