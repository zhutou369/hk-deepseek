<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="baidu-site-verification" content="codeva-1zDnTk8YZ4">
  {% set docTitle = title or site.title %}
  {% set metaDescription = description or site.description %}
  {% set canonicalPath = canonicalUrl or page.url or "/" %}
  {% set canonical = site.url + canonicalPath %}
  <title>{% if page.url != "/" %}{{ docTitle }} | {{ site.brand }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ metaDescription }}">
  <meta name="keywords" content="{{ pageKeywords or site.keywords }}">
  {% if noindex %}
  <meta name="robots" content="noindex,follow">
  {% else %}
  <meta name="robots" content="index,follow,max-image-preview:large">
  {% endif %}
  <link rel="canonical" href="{{ canonical }}">
  <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ docTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:site_name" content="{{ site.brand }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta name="twitter:card" content="summary">
  <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.brand,
  "url": site.url,
  "description": site.description
} | dump | safe }}
  </script>
  <link rel="stylesheet" href="/css/style.css">
  <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" defer></script>
  <script>window.addEventListener("load",function(){if(window.LA){LA.init({id:"{{ site.laId }}",ck:"{{ site.laId }}"})}})</script>
</head>
<body>
  <header class="site-header">
    <div class="container header-nav">
      {% if page.url == "/" %}
        <h1 class="logo" style="margin:0;"><a href="/">{{ site.brand }}</a></h1>
      {% else %}
        <div class="logo"><a href="/">{{ site.brand }}</a></div>
      {% endif %}
      <nav>
        <ul class="nav-links">
          <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>首頁</a></li>
          <li><a href="/posts/" {% if page.url.startsWith('/posts/') %}class="active"{% endif %}>技術文章</a></li>
        </ul>
      </nav>
    </div>
  </header>
  <main>{{ content | safe }}</main>
  <footer class="site-footer">
    <div class="container">
      <div class="friend-section">
        <h4>相關 DeepSeek 資料站</h4>
        <div class="friend-grid">
          <a href="https://deepseek-chat.com" target="_blank" rel="noopener">DeepSeek 對話入口整理</a>
          <a href="https://deepseek-in.com" target="_blank" rel="noopener">DeepSeek 產業應用資料</a>
          <a href="https://deepseek-1.com" target="_blank" rel="noopener">DeepSeek 技術文章</a>
          <a href="https://deepseek-my.com" target="_blank" rel="noopener">DeepSeek 馬來西亞資料</a>
        </div>
      </div>
      <div class="copy">
        <p>&copy; 2026 {{ site.brand }} · 本站為第三方使用說明與技術整理，非 DeepSeek 官方網站。</p>
      </div>
    </div>
  </footer>
</body>
</html>
